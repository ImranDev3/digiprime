<%- include('layout', { body: `
<div class="page-head">
  <h1><i class="fas fa-box"></i> Products</h1>
  <a href="/admin/products/new" class="btn btn-primary"><i class="fas fa-plus"></i> Add Product</a>
</div>
<div class="card">
  <table class="table">
    <thead>
      <tr><th>Name</th><th>Category</th><th>Variations</th><th>Status</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% products.forEach(function(p) { %>
      <tr>
        <td><%= p.name %><% if (p.badge) { %> <span class="badge-sm"><%= p.badge %></span><% } %></td>
        <td><%= p.category ? p.category.name : '-' %></td>
        <td><%= p.variations.length %></td>
        <td>
          <form method="POST" action="/admin/products/toggle/<%= p._id %>" style="display:inline">
            <button class="btn-sm <%= p.visible ? 'green' : 'dim' %>"><%= p.visible ? 'Visible' : 'Hidden' %></button>
          </form>
        </td>
        <td class="action-cell">
          <a href="/admin/products/edit/<%= p._id %>" class="btn-sm"><i class="fas fa-edit"></i></a>
          <form method="POST" action="/admin/products/delete/<%= p._id %>" style="display:inline" onsubmit="return confirm('Delete this product?')">
            <button class="btn-sm danger"><i class="fas fa-trash"></i></button>
          </form>
        </td>
      </tr>
      <% }) %>
      <% if (!products.length) { %>
      <tr><td colspan="5" style="text-align:center;color:#6b7280;padding:24px">No products yet. <a href="/admin/products/new" style="color:#818cf8">Add one.</a></td></tr>
      <% } %>
    </tbody>
  </table>
</div>
` }) %>