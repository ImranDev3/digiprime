<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login - Digital SubDesk</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: #07080c; color: #eef2f6; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .login-box { background: #151820; border: 1px solid rgba(255,255,255,.06); border-radius: 12px; padding: 40px 36px; width: 360px; box-shadow: 0 24px 64px rgba(0,0,0,.55); }
    .login-logo { font-size: 1.1rem; font-weight: 700; text-align: center; margin-bottom: 24px; letter-spacing: -.03em; }
    .login-logo .accent { color: #818cf8; }
    .login-box label { display: block; font-size: .72rem; color: #6b7280; font-weight: 500; margin-bottom: 5px; }
    .login-box input { width: 100%; padding: 10px 14px; border: 1px solid rgba(255,255,255,.06); border-radius: 8px; background: #07080c; color: #eef2f6; font-size: .85rem; font-family: inherit; outline: none; margin-bottom: 14px; }
    .login-box input:focus { border-color: rgba(129,140,248,.3); box-shadow: 0 0 0 3px rgba(129,140,248,.06); }
    .login-box button { width: 100%; padding: 11px; border-radius: 8px; border: none; background: #818cf8; color: #fff; font-size: .8rem; font-family: inherit; font-weight: 600; cursor: pointer; }
    .login-box button:hover { opacity: .9; }
    .error { color: #ef4444; font-size: .75rem; text-align: center; margin-bottom: 12px; }
  </style>
</head>
<body>
  <div class="login-box">
    <div class="login-logo">&#9670; Digital <span class="accent">SubDesk</span></div>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="POST">
      <label>Username</label>
      <input type="text" name="username" placeholder="admin" required />
      <label>Password</label>
      <input type="password" name="password" placeholder="********" required />
      <button type="submit">Sign In</button>
    </form>
  </div>
</body>
</html>
